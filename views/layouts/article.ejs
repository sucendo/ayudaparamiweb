<%
  const resolveArticleToneClass = function(articleMetadata) {
    const heroClass = String(articleMetadata && articleMetadata.heroClass ? articleMetadata.heroClass : '').toLowerCase();
    const themeColor = String(articleMetadata && articleMetadata.themeColor ? articleMetadata.themeColor : '').toLowerCase();
    const toneByHero = {
      'bg-purple': 'ct-purple',
      'bg-orange': 'ct-orange',
      'bg-blue': 'ct-blue',
      'bg-green': 'ct-green',
      'bg-red': 'ct-red',
      'bg-yellow': 'ct-yellow'
    };

    if (toneByHero[heroClass]) return toneByHero[heroClass];
    if (heroClass.indexOf('purple') !== -1) return 'ct-purple';
    if (heroClass.indexOf('orange') !== -1) return 'ct-orange';
    if (heroClass.indexOf('blue') !== -1) return 'ct-blue';
    if (heroClass.indexOf('green') !== -1) return 'ct-green';
    if (heroClass.indexOf('red') !== -1) return 'ct-red';
    if (heroClass.indexOf('yellow') !== -1) return 'ct-yellow';

    if (themeColor === '#64448f') return 'ct-purple';
    if (themeColor === '#e2674a') return 'ct-orange';
    if (themeColor === '#46a4da') return 'ct-blue';
    if (themeColor === '#58b391') return 'ct-green';
    if (themeColor === '#f06a6a') return 'ct-red';
    if (themeColor === '#d4bf4a') return 'ct-yellow';

    return 'ct-purple';
  };

  const formatDate = function(dateString) {
    const [year, month, day] = String(dateString || '').split('-');
    return (day && month && year) ? `${day}/${month}/${year}` : dateString;
  };

  const articleToneClass = resolveArticleToneClass(metadata || {});
  const siteName = 'Ayuda para mi Web';
  const siteUrl = 'https://ayudaparamiweb.com';
  const authorUrl = `${siteUrl}/sucender`;
  const publisherLogoUrl = `${siteUrl}/img/author/sucender.png`;
  const featuredImageUrl = metadata.featuredImage
    ? `${siteUrl}${String(metadata.featuredImage).startsWith('/') ? metadata.featuredImage : `/${metadata.featuredImage}`}`
    : `${siteUrl}/img/logo-color.svg`;

  const ratingValueNum = Number(metadata && metadata.ratingValue ? metadata.ratingValue : 0);
  const ratingCountNum = Number(metadata && metadata.ratingCount ? metadata.ratingCount : 0);
  const maxStars = 5;
%>

<div class="ct-main ct-main-post" id="ct-main" role="main" data-article-tone="<%= articleToneClass %>">
  <div class="ct-post">
    <article class="post type-post status-publish format-standard has-post-thumbnail hentry" itemscope itemtype="https://schema.org/Article">
      <header>
        <div class="ct-subline entry-meta">
          <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
            <div itemprop="logo" itemscope itemtype="https://schema.org/ImageObject">
              <img alt="<%= siteName %>" src="<%= publisherLogoUrl %>" class="avatar avatar-36 photo" height="36" width="36">
              <meta itemprop="url" content="<%= publisherLogoUrl %>">
              <meta itemprop="width" content="36">
              <meta itemprop="height" content="36">
            </div>
            <meta itemprop="name" content="<%= siteName %>">
          </div>

          <div class="ct-subline__author">
            <span class="byline author vcard" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <meta itemprop="name" content="<%= metadata.author %>">
              <meta itemprop="url" content="<%= authorUrl %>">
              <a href="/sucender" title="Posts by <%= metadata.author %>" rel="author"><%= metadata.author %></a>
            </span>
            in
            <a href="/articulos">Artículos</a>
          </div>

          <div class="ct-subline__time">
            <% if (metadata.modifiedDate) { %>
              Actualizado el
              <time class="ct-subline__pubtime" pubdate="pubdate" itemprop="dateModified" content="<%= metadata.modifiedDate %>"><%= formatDate(metadata.modifiedDate) %></time>
            <% } %>
            Publicado el
            <time class="ct-subline__pubtime" pubdate="pubdate" itemprop="datePublished" content="<%= metadata.publishedDate %>"><%= formatDate(metadata.publishedDate) %></time>

            <% if (ratingCountNum > 0 && ratingValueNum > 0) { %>
              <div
                class="ct-rating-summary"
                aria-label="Valoración media de <%= metadata.ratingValue %> sobre 5 basada en <%= metadata.ratingCount %> votos"
                style="display:inline-flex;align-items:center;gap:8px;margin-left:10px;font-size:14px;line-height:1.2;"
              >
                <span class="ct-rating-stars" aria-hidden="true" style="display:inline-flex;gap:2px;">
                  <% for (let i = 1; i <= maxStars; i++) { %>
                    <% if (ratingValueNum >= i) { %>
                      <span style="color:#f5b301;font-size:16px;">★</span>
                    <% } else if (ratingValueNum >= (i - 0.5)) { %>
                      <span style="color:#f5b301;opacity:.55;font-size:16px;">★</span>
                    <% } else { %>
                      <span style="color:#cfcfcf;font-size:16px;">★</span>
                    <% } %>
                  <% } %>
                </span>
                <span class="ct-rating-text" style="color:#444;">
                  <strong><%= metadata.ratingValue %></strong>/5 · <strong><%= metadata.ratingCount %></strong> votos
                </span>
              </div>
            <% } %>
          </div>
        </div>

        <h1 class="ct-h-shd entry-title" itemprop="headline"><%= metadata.title %></h1>
      </header>

      <div class="ct-post-content">
        <div class="ct-post-excerpt" itemprop="description"><%= metadata.description %></div>

        <div class="ct-post-featured-img" itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
          <img src="<%= metadata.featuredImage %>" alt="<%= metadata.title %>">
          <meta itemprop="url" content="<%= featuredImageUrl %>">
          <meta itemprop="width" content="800">
          <meta itemprop="height" content="500">
        </div>

        <%- metadata.bodyHtml %>
      </div>
    </article>

    <% if ((metadata.tags || []).length) { %>
      <p class="ct-tags">Etiquetado en:
      <% metadata.tags.forEach(function(tag) { %>
        <a href="/" rel="tag"><%= tag %></a>
      <% }); %>
      </p>
    <% } %>
    <div class="clr"></div>
  </div>
  <div class="ct-row">
    <div class="ct-author-info ct-box <%= articleToneClass %>"><%- include('../authors/sucender-short.ejs') %></div>
  </div>
</div>
<aside class="ct-sidebar article-sidebar"><%- include('../partials/aside.ejs') %></aside>
