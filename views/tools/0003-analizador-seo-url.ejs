<!doctype html>
<html dir="ltr" lang="es" xml:lang="es" class="js js canvas fontface generatedcontent wf-proximanova-n7-active wf-proximanova-i7-active wf-proximanova-n4-active wf-proximanova-i4-active wf-brandongrotesque-n7-active wf-active">
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="theme-color" content="#537b7b">
		<meta name="apple-mobile-web-app-status-bar-style" content="#537b7b">
		<meta name="msapplication-navbutton-color" content="#537b7b">

		<title>Analizador SEO de URL | Ayuda para mi Web</title>
		<meta name="description" content="Analiza el SEO on-page de cualquier URL con un informe claro, puntuación por bloques y recomendaciones accionables en español." />
		<meta name="keywords" content="analizador SEO, auditoría SEO, SEO on-page, metadatos, title, headings, indexabilidad" />
		<meta name="author" content="Sucender" />
		<link rel="canonical" href="http://www.ayudaparamiweb.com/analizador-seo-url" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Analizador SEO de URL | Ayuda para mi Web" />
		<meta property="og:description" content="Herramienta gratuita para auditar metadatos, estructura y señales on-page a partir del HTML de una URL." />
		<meta property="og:url" content="http://www.ayudaparamiweb.com/analizador-seo-url" />
		<meta property="og:site_name" content="Ayuda para mi Web" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content="Analizador SEO de URL | Ayuda para mi Web" />
		<meta name="twitter:description" content="Evalúa title, headings, imágenes, enlaces y otros factores on-page de forma rápida." />

		<%- include('../partials/head.ejs') %>
		<link rel="stylesheet" href="/css/seo-analyzer-tool.css">
	</head>

	<body id="codrops-body">
		<div class="ct-container">
			<%- include('../partials/header.ejs') %>

			<div class="ct-content">
				<div class="ct-inner">
					<div class="ct-main ct-main-post" role="main">
						<div class="ct-post">
							<article class="post-1 post type-post status-publish format-standard has-post-thumbnail hentry">
								<header>
									<h1 class="ct-h-shd entry-title">Analizador SEO de URL</h1>
								</header>
								<div class="ct-post-content seo-tool">
									<div class="ct-post-excerpt">Introduce una URL y obtén un informe SEO realista: rastreo básico, metadatos, contenido, imágenes, enlazado, social/schema e indexabilidad.</div>

										<form id="seo-analyzer-form" class="seo-tool__form">
											<label for="seo-url" class="seo-tool__label">URL (opcional, solo si permite CORS)</label>
											<div class="seo-tool__row">
												<input id="seo-url" name="url" type="url" placeholder="https://www.ejemplo.com" />
												<button id="seo-load-url" type="button" class="seo-tool__secondary">Cargar HTML</button>
											</div>
											<label for="seo-html-source" class="seo-tool__label">HTML de la página</label>
											<textarea id="seo-html-source" name="htmlSource" rows="10" placeholder="Pega aquí el HTML completo de la página..." required></textarea>
											<div class="seo-tool__row">
												<button type="submit">Analizar on-page</button>
											</div>
											<p class="seo-tool__hint">Modo 100% compatible con GH Pages: análisis local del HTML accesible (title, headings, keywords, imágenes, enlaces, metadatos). Métricas como DA/PA/CF/TF/backlinks no están disponibles sin APIs externas.</p>
										</form>

									<div id="seo-state" class="seo-tool__state" aria-live="polite"></div>
									<div id="seo-report" class="seo-report" hidden></div>
								</div>
								</article>

								<p class="ct-tags">Tagged with: <a href="http://www.ayudaparamiweb.com/" rel="tag">Herramientas</a> <a href="http://www.ayudaparamiweb.com/" rel="tag">SEO</a> <a href="http://www.ayudaparamiweb.com/" rel="tag">Auditoría</a></p>

								<div class="ct-row">
									<div class="ct-author-info ct-box ct-purple">
										<%- include('../authors/sucender-short.ejs') %>
									</div>
								</div>
							</div>
						</div>

					<aside class="ct-sidebar">
						<%- include('../partials/aside.ejs') %>
					</aside>

					<div class="clr"></div>
				</div>
			</div>

			<footer class="ct-footer">
				<%- include('../partials/footer.ejs') %>
			</footer>
		</div>

		<script src="/js/seo-analyzer-tool.js"></script>
	</body>
</html>
